APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173

REDIS_URL=redis://localhost:6379/0
REDIS_STATE_TTL_SEC=3600

RAG_STORE_BACKEND=memory
RAG_STORE_FILE_PATH=./data/rag_store.json

API_KEYS=dev-key
RATE_LIMIT_PER_MINUTE=10
MAX_REQUEST_COST_USD=0.02

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pr-fresh-roster-48

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
CHATGPT_API_KEY=

ROS2_BRIDGE_LEADER_COMMAND_URL=http://127.0.0.1:9102/bridge/leader-command
ROS2_BRIDGE_MISSION_CONTROL_URL=http://127.0.0.1:9102/bridge/mission-control
ROS2_LEADER_TOPIC=/swarm/leader_command
ROS2_MISSION_CONTROL_TOPIC=/swarm/mission_control
MAVSDK_BRIDGE_LEADER_COMMAND_URL=http://127.0.0.1:9101/bridge/leader-command
MAVSDK_BRIDGE_MISSION_CONTROL_URL=http://127.0.0.1:9101/bridge/mission-control
MAVSDK_SYSTEM_ADDRESS=udp://:14540
MAVSDK_TAKEOFF_ALTITUDE_M=10

DEFAULT_VISION_STREAM_URL=
